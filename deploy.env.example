# Copy to deploy.env and fill real values. Do not commit deploy.env.
# Use KEY=value with no spaces around "=".
# In SUPABASE_DB_URL, URL-encode special password characters. Example: @ becomes %40.

# Render
RENDER_API_KEY=
RENDER_OWNER_ID=
GIT_REPO_URL=
GIT_BRANCH=main
GITHUB_TOKEN=
GIT_AUTHOR_NAME=CivicPulse Deploy
GIT_AUTHOR_EMAIL=civicpulse@example.com

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_DB_URL=

# Backend auth
JWT_SECRET=

# AWS S3 media uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
CDN_BASE_URL=

# OpenAI voice transcription/NLP
OPENAI_API_KEY=
